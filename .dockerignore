# Keep the build context small and never ship local state or secrets.
.venv/
**/__pycache__/
**/*.py[cod]
*.egg-info/
.pytest_cache/

# Local data: DB, downloaded SciFact, FAISS indexes, uploaded collections
data/
results/

# Frontend build artifacts / deps (rebuilt inside the image)
frontend/node_modules/
frontend/dist/

# Secrets (set these as env vars in Render, NOT in the image)
.env

# VCS / editor
.git/
.gitignore
.vscode/
.idea/
.DS_Store
